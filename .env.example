# Handle do X (sem @) — usado em URLs como x.com/seuuser/likes
X_USER_HANDLE=seuusuario

# Opcional: Chrome/Edge instalado em vez do Chromium do Playwright
# PLAYWRIGHT_CHANNEL=chrome

# Diretórios (padrão: ./data dentro do projeto)
# DATA_DIR=./data
# O Playwright usa HOME=data/.playwright-home para o Crashpad não escrever em ~/Library (sandbox).

# OpenAI — opcional; sem chave, tópicos usam heurística local e rascunhos ficam limitados
OPENAI_API_KEY=
# Modelo para texto e embeddings (opcional)
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# API do app (Express)
PORT=3847

# Token de autenticação da API — se vazio, auth é desabilitado (dev mode)
API_TOKEN=

# Database provider: sqlite (default, local) ou supabase (cloud)
DB_PROVIDER=sqlite

# Supabase — necessário quando DB_PROVIDER=supabase
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_KEY=sb_publishable_xxx
